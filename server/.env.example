# Server Configuration
PORT=5000

# MongoDB Connection String
# For local development: mongodb://localhost:27017/solarnode
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/solarnode
MONGODB_URI=mongodb://localhost:27017/solarnode

# CORS Configuration
# Comma-separated list of allowed origins
# For development: http://localhost:5173
# For production: https://your-vercel-app.vercel.app
CORS_ORIGIN=http://localhost:5173
